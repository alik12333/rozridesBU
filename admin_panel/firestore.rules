rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             (
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') in ['admin', 'super_admin'] ||
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('roles', {}).get('isAdmin', false) == true
             );
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && (
        request.auth.uid == userId ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['hostRating', 'hostReviewCount']) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['renterRating', 'renterReviewCount']) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['hostRating', 'hostReviewCount', 'renterRating', 'renterReviewCount'])
      );
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isAdmin();
      
      match /notifications/{notificationId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow create: if isAuthenticated();
        allow update, delete: if isAuthenticated() && request.auth.uid == userId;
      }
    }
    
    match /listings/{listingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.ownerId == request.auth.uid || 
        isAdmin() || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['bookedDateRanges']) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['averageRating', 'totalReviews', 'ratingBreakdown'])
      );
      allow delete: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }
    
    match /bookings/{bookingId} {
      allow read: if isAuthenticated();
      
      // Only renters can create a booking (and it must have their uid as renterId)
      allow create: if isAuthenticated() && request.resource.data.renterId == request.auth.uid;
      
      // Field-level update rules — each role can only touch the fields it owns
      allow update: if isAuthenticated() && (
        isAdmin() ||
        // Renter can cancel (status → cancelled) or update cancellationReason
        (
          resource.data.renterId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'cancellationReason', 'updatedAt', 
                      'tripStartedAt', 'tripEndedAt', 'cashPayments'])
        ) ||
        // Host can accept, decline, start trip (status → active), close trip (status → completed)
        (
          resource.data.hostId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'rejectionReason', 'updatedAt',
                      'bookedDateRanges', 'warningNotificationSent',
                      'tripStartedAt', 'tripEndedAt', 'cashPayments',
                      'preHandoverCompleted', 'postHandoverCompleted', 
                      'proposedSettlement', 'cancellationReason'])
        ) ||
        // Review status updates (either party submitting review)
        (
          (resource.data.renterId == request.auth.uid || resource.data.hostId == request.auth.uid) &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['reviewStatus', 'updatedAt'])
        )
      );
      
      allow delete: if isAdmin();

      match /timeline/{eventId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if isAdmin();
      }

      match /inspections/{inspectionId} {
        allow read: if isAuthenticated() && (
          get(/databases/$(database)/documents/bookings/$(bookingId)).data.hostId == request.auth.uid ||
          get(/databases/$(database)/documents/bookings/$(bookingId)).data.renterId == request.auth.uid ||
          isAdmin()
        );
        allow create, update: if isAuthenticated() && (
          get(/databases/$(database)/documents/bookings/$(bookingId)).data.hostId == request.auth.uid ||
          get(/databases/$(database)/documents/bookings/$(bookingId)).data.renterId == request.auth.uid
        );
        allow delete: if isAdmin();
      }
    }

    match /admins/{adminId} {
      allow read: if isAuthenticated() && request.auth.uid == adminId;
      allow write: if false;
    }

    match /conversations/{conversationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if isAdmin();
      }
    }
    
    // ── adminAlerts (camelCase — matches Cloud Function writes) ──────────────
    match /adminAlerts/{alertId} {
      allow read, update, delete: if isAdmin();
      allow create: if isAuthenticated();
    }

    match /damageClaims/{claimId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated();
      allow update: if isAdmin() || (
        isAuthenticated() && (
          (resource.data.hostId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['hostConfirmed', 'hostConfirmedAt', 'status', 'resolvedAt'])) ||
          (resource.data.renterId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['renterConfirmed', 'renterConfirmedAt', 'status', 'resolvedAt']))
        )
      );
      allow delete: if false;
    }

    match /reviews/{reviewId} {
      allow create: if isAuthenticated() && request.resource.data.reviewerId == request.auth.uid;
      allow read: if isAuthenticated();
      allow update: if isAdmin() || (
        isAuthenticated() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isPublic']) &&
        request.resource.data.isPublic == true
      );
      allow delete: if false;
    }

    match /scheduledNotifications/{notifId} {
      allow create: if isAuthenticated();
      // Only Cloud Functions (admin SDK) read and update these
      allow read, update: if false;
      allow delete: if false;
    }
  }
}
