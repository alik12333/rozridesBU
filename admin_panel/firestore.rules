rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isAdmin();
      
      match /notifications/{notificationId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow create: if isAuthenticated();
        allow update, delete: if isAuthenticated() && request.auth.uid == userId;
      }
    }
    
    match /listings/{listingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.ownerId == request.auth.uid || 
        isAdmin() || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['bookedDateRanges'])
      );
      allow delete: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }
    
    match /bookings/{bookingId} {
      // Relaxed read for debugging but still requires auth
      // In production, we should ensure queries filter by hostId or renterId
      allow read: if isAuthenticated();
      
      allow create: if isAuthenticated() && request.resource.data.renterId == request.auth.uid;
                      
      allow update: if isAuthenticated() && (
        resource.data.renterId == request.auth.uid || 
        resource.data.hostId == request.auth.uid || 
        isAdmin()
      );
      
      allow delete: if isAdmin();

      match /timeline/{eventId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if isAdmin();
      }

      match /inspections/{inspectionId} {
        allow read: if isAuthenticated() && (
          resource.data.bookingId == bookingId ||
          get(/databases/$(database)/documents/bookings/$(bookingId)).data.hostId == request.auth.uid ||
          get(/databases/$(database)/documents/bookings/$(bookingId)).data.renterId == request.auth.uid
        );
        allow create, update: if isAuthenticated() &&
          get(/databases/$(database)/documents/bookings/$(bookingId)).data.hostId == request.auth.uid;
        allow delete: if isAdmin();
      }
    }

    match /admins/{adminId} {
      allow read: if isAuthenticated() && request.auth.uid == adminId;
      allow write: if false;
    }

    match /conversations/{conversationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if isAdmin();
      }
    }
    
    match /admin_alerts/{alertId} {
      allow read, update, delete: if isAdmin();
      allow create: if isAuthenticated();
    }
  }
}
